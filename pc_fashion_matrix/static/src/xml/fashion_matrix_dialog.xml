<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        FashionMatrixDialog
        Enhanced matrix popup with product image, color swatches and totals.
        Replaces the standard ProductMatrixDialog for products with Color + Size.
    -->
    <t t-name="pc_fashion_matrix.FashionMatrixDialog">
        <Dialog size="size" title.translate="Choose Product Variants" withBodyPadding="false">
            <div t-ref="fashionMatrix" class="o_fashion_matrix_dialog d-flex flex-column h-100">

                <!-- LOADING STATE -->
                <div t-if="state.loading" class="d-flex justify-content-center align-items-center flex-grow-1 py-5">
                    <div class="text-center">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Loading product data...</p>
                    </div>
                </div>

                <!-- MAIN CONTENT (after loading) -->
                <div t-if="!state.loading and state.product"
                     class="o_fashion_matrix_body d-flex flex-grow-1 overflow-hidden">

                    <!-- ==================== LEFT PANEL: Image ==================== -->
                    <div class="o_fashion_matrix_left_panel d-flex flex-column">

                        <!-- Main Image Area -->
                        <div class="o_fashion_matrix_image_area flex-grow-1 d-flex align-items-center justify-content-center position-relative">
                            <t t-if="currentImage">
                                <img t-att-src="currentImage.src"
                                     class="o_fashion_matrix_main_img"
                                     alt="Product image"/>
                                <!-- Navigation arrows -->
                                <button t-if="hasMultipleImages"
                                        class="btn o_fashion_img_nav o_fashion_img_nav_prev"
                                        t-on-click="onPrevImage">
                                    <i class="fa fa-chevron-left"/>
                                </button>
                                <button t-if="hasMultipleImages"
                                        class="btn o_fashion_img_nav o_fashion_img_nav_next"
                                        t-on-click="onNextImage">
                                    <i class="fa fa-chevron-right"/>
                                </button>
                            </t>
                            <t t-else="">
                                <div class="text-center text-muted py-5">
                                    <i class="fa fa-image fa-5x mb-3 d-block" style="opacity: 0.3;"/>
                                    <p class="mb-0">No image</p>
                                </div>
                            </t>
                        </div>

                        <!-- Thumbnail Strip -->
                        <div t-if="hasMultipleImages"
                             class="o_fashion_matrix_thumbstrip d-flex gap-2 p-2 overflow-auto justify-content-center">
                            <t t-foreach="state.product.images" t-as="img" t-key="img.id">
                                <div class="o_fashion_matrix_thumb"
                                     t-att-class="{'active': img_index === state.currentImageIndex}"
                                     t-on-click="() => this.onSelectThumbnail(img_index)">
                                    <img t-att-src="img.src" alt="Thumbnail"/>
                                </div>
                            </t>
                        </div>

                        <!-- Quick Product Info under image -->
                        <div class="o_fashion_matrix_img_info p-3 border-top">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span t-if="state.product.seller_name"
                                      class="text-muted text-uppercase small fw-semibold">
                                    <t t-esc="state.product.seller_name"/>
                                </span>
                                <span t-if="state.product.gender_display"
                                      class="badge badge-sm"
                                      t-att-class="genderBadgeClass">
                                    <t t-esc="state.product.gender_display"/>
                                </span>
                                <span t-if="state.product.season"
                                      class="badge badge-sm bg-dark">
                                    <t t-esc="state.product.season_code || state.product.season"/>
                                </span>
                            </div>
                            <div class="fw-bold fs-5 mb-1">
                                <t t-esc="state.product.name"/>
                            </div>
                            <div class="text-muted small">
                                <span t-if="state.product.default_code" class="me-3">
                                    <i class="fa fa-barcode me-1"/>
                                    <t t-esc="state.product.default_code"/>
                                </span>
                                <span t-if="state.product.family">
                                    <i class="fa fa-tag me-1"/>
                                    <t t-esc="state.product.family"/>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- ==================== RIGHT PANEL: Matrix ==================== -->
                    <div class="o_fashion_matrix_right_panel d-flex flex-column flex-grow-1 overflow-hidden">

                        <!-- Price Bar -->
                        <div class="o_fashion_matrix_price_bar d-flex align-items-center gap-4 px-4 py-2 border-bottom">
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="text-muted small">PVP</span>
                                <span class="fs-4 fw-bold">
                                    <t t-esc="formatCurrency(state.product.list_price)"/>
                                </span>
                            </div>
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="text-muted small">Cost</span>
                                <span class="fs-5 fw-bold">
                                    <t t-esc="formatCurrency(costPrice)"/>
                                </span>
                            </div>
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="text-muted small">Margin</span>
                                <span class="fs-6 fw-bold" t-att-class="marginClass">
                                    <t t-esc="unitMarginPercent.toFixed(1)"/>%
                                </span>
                            </div>
                            <div class="ms-auto">
                                <button class="btn btn-outline-secondary btn-sm"
                                        t-on-click="onClearAll"
                                        title="Clear all quantities">
                                    <i class="fa fa-eraser me-1"/>Clear
                                </button>
                            </div>
                        </div>

                        <!-- Color Swatches -->
                        <div class="o_fashion_matrix_swatches px-4 py-2 border-bottom">
                            <div class="d-flex align-items-center gap-1 flex-wrap">
                                <span class="small text-muted me-2 fw-semibold">Colors:</span>
                                <t t-foreach="state.product.colors" t-as="color" t-key="color.id">
                                    <div class="o_fashion_color_swatch d-flex align-items-center gap-1 px-2 py-1 rounded-pill border cursor-pointer"
                                         t-att-class="{'o_fashion_swatch_active': state.activeColorId === color.id}"
                                         t-on-click="() => this.onSelectColor(color.id)"
                                         t-att-title="color.name">
                                        <span class="o_fashion_color_dot"
                                              t-att-style="'background-color: ' + color.html_color + ';'"/>
                                        <span class="small"><t t-esc="color.name"/></span>
                                    </div>
                                </t>
                                <button t-if="state.activeColorId"
                                        class="btn btn-link btn-sm text-muted ms-2 p-0"
                                        t-on-click="() => this.state.activeColorId = null">
                                    <i class="fa fa-times me-1"/>Show All
                                </button>
                            </div>
                        </div>

                        <!-- Size x Color Grid (scrollable) -->
                        <div class="o_fashion_matrix_grid_wrapper flex-grow-1 overflow-auto px-4 py-3">
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered o_fashion_matrix_table mb-0">
                                    <thead>
                                        <tr class="o_fashion_matrix_thead_row">
                                            <th class="o_fashion_matrix_corner">
                                                Color / Size
                                            </th>
                                            <t t-foreach="state.product.sizes" t-as="size" t-key="size.id">
                                                <th class="text-center o_fashion_matrix_size_th">
                                                    <t t-esc="size.name"/>
                                                </th>
                                            </t>
                                            <th class="text-center o_fashion_matrix_total_th">
                                                Total
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="visibleColors" t-as="color" t-key="color.id">
                                            <tr class="o_fashion_matrix_body_row">
                                                <!-- Color label -->
                                                <td class="o_fashion_matrix_color_label">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="o_fashion_color_dot"
                                                              t-att-style="'background-color: ' + color.html_color + ';'"/>
                                                        <span class="small fw-semibold text-truncate">
                                                            <t t-esc="color.name"/>
                                                        </span>
                                                    </div>
                                                </td>
                                                <!-- Quantity cells -->
                                                <t t-foreach="state.product.sizes" t-as="size" t-key="size.id">
                                                    <td class="o_fashion_matrix_qty_cell p-0">
                                                        <input type="number"
                                                               class="o_fashion_matrix_input"
                                                               min="0"
                                                               t-att-value="getQty(color.id, size.id)"
                                                               t-on-change="(ev) => this.onQtyChange(color.id, size.id, ev)"
                                                               t-on-keydown="(ev) => this.onQtyKeydown(color.id, size.id, ev)"
                                                               t-att-data-color="color.id"
                                                               t-att-data-size="size.id"
                                                               onClick="this.select();"/>
                                                    </td>
                                                </t>
                                                <!-- Row total -->
                                                <td class="o_fashion_matrix_row_total text-center fw-bold">
                                                    <t t-esc="getRowTotal(color.id)"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr class="o_fashion_matrix_tfoot_row">
                                            <td class="fw-bold text-end">Total</td>
                                            <t t-foreach="state.product.sizes" t-as="size" t-key="size.id">
                                                <td class="text-center fw-bold o_fashion_matrix_col_total">
                                                    <t t-esc="getColTotal(size.id)"/>
                                                </td>
                                            </t>
                                            <td class="text-center fw-bold o_fashion_matrix_grand_total">
                                                <t t-esc="grandTotalUnits"/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>

                        <!-- Order Summary Bar -->
                        <div class="o_fashion_matrix_summary_bar d-flex align-items-center justify-content-between px-4 py-3 border-top">
                            <div class="d-flex gap-4">
                                <div>
                                    <span class="small text-muted d-block">Units</span>
                                    <span class="fs-5 fw-bold"><t t-esc="grandTotalUnits"/></span>
                                </div>
                                <div>
                                    <span class="small text-muted d-block">PVP Value</span>
                                    <span class="fs-5 fw-bold text-success">
                                        <t t-esc="formatCurrency(grandTotalPVP)"/>
                                    </span>
                                </div>
                                <div>
                                    <span class="small text-muted d-block">Cost Value</span>
                                    <span class="fs-5 fw-bold">
                                        <t t-esc="formatCurrency(grandTotalCost)"/>
                                    </span>
                                </div>
                                <div>
                                    <span class="small text-muted d-block">Margin</span>
                                    <span class="fs-5 fw-bold" t-att-class="marginClass">
                                        <t t-esc="marginPercent.toFixed(1)"/>%
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FALLBACK: no fashion data (product without color/size) -->
                <div t-if="!state.loading and !state.product"
                     class="d-flex justify-content-center align-items-center flex-grow-1 py-5">
                    <div class="text-center text-muted">
                        <i class="fa fa-exclamation-triangle fa-3x mb-3"/>
                        <p>Unable to load product fashion data.</p>
                    </div>
                </div>

            </div>

            <!-- Footer: Confirm / Discard -->
            <t t-set-slot="footer">
                <button class="btn btn-primary"
                        t-on-click="_onConfirm"
                        t-att-disabled="grandTotalUnits === 0">
                    Confirm
                </button>
                <button class="btn btn-secondary" t-on-click="_onDiscard">
                    Discard
                </button>
            </t>
        </Dialog>
    </t>

</templates>
