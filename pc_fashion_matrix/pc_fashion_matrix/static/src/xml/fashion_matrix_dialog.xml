<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pc_fashion_matrix.FashionMatrixDialog" t-inherit="product_matrix.dialog" t-inherit-mode="primary">
        <xpath expr="//Dialog" position="attributes">
            <attribute name="size">'xl'</attribute>
        </xpath>

        <!-- Cabecera con información de precios (antes del grid) -->
        <xpath expr="//div[hasclass('o_matrix')]" position="before">
            <div class="fashion-matrix-header d-flex justify-content-between align-items-center p-3 mb-3 bg-light rounded" t-if="props.is_fashion_mode">
                <div class="d-flex gap-4">
                    <div>
                        <small class="text-muted">Coste unitario</small>
                        <div class="fw-bold fs-5" t-esc="props.cost_price ? props.cost_price.toFixed(2) + ' €' : '-'"/>
                    </div>
                    <div>
                        <small class="text-muted">PVP</small>
                        <div class="fw-bold fs-5" t-esc="props.sale_price ? props.sale_price.toFixed(2) + ' €' : '-'"/>
                    </div>
                    <div>
                        <small class="text-muted">Margen</small>
                        <div class="fw-bold fs-5 text-success" t-if="props.cost_price and props.sale_price"
                             t-esc="((1 - props.cost_price / props.sale_price) * 100).toFixed(0) + '%'"/>
                    </div>
                </div>
                <div class="text-end">
                    <small class="text-muted">Total unidades</small>
                    <div class="fw-bold fs-4 text-primary" t-esc="state.grandTotal"/>
                    <small class="text-muted">Importe total</small>
                    <div class="fw-bold fs-5" t-esc="state.totalAmount.toFixed(2) + ' €'"/>
                </div>
            </div>
        </xpath>

        <!-- Distribución por tienda (después del grid) -->
        <xpath expr="//div[hasclass('o_matrix')]" position="after">
            <div t-if="props.is_fashion_mode and state.storeDistribution.length > 0" class="mt-4">
                <StoreDistribution
                    distribution="state.storeDistribution"
                    grandTotal="state.grandTotal"
                    costPrice="props.cost_price || 0"/>
            </div>
        </xpath>
    </t>

</templates>
