<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_form_fashion" model="ir.ui.view">
        <field name="name">sale.order.form.fashion</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']/.." position="after">
                <group string="Información moda" name="fashion_info">
                    <group>
                        <field name="fashion_season_id"/>
                        <field name="fashion_gender"/>
                    </group>
                    <group>
                        <field name="fashion_family_id"/>
                        <field name="distribution_profile_id"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
