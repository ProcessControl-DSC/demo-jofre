<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Product Template: Extend Form View with Fashion Fields -->
    <record id="product_template_form_view_fashion" model="ir.ui.view">
        <field name="name">product.template.form.fashion</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="after">
                <page string="Fashion" name="fashion_info">
                    <group>
                        <group string="Classification">
                            <field name="fashion_season_id"/>
                            <field name="fashion_family_id"/>
                            <field name="fashion_gender"/>
                        </group>
                        <group string="Supplier References">
                            <field name="fashion_supplier_style"
                                   placeholder="Supplier style code"/>
                            <field name="fashion_supplier_fabric"
                                   placeholder="Supplier fabric code"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Product Template: Extend Search View with Fashion Filters -->
    <record id="product_template_search_view_fashion" model="ir.ui.view">
        <field name="name">product.template.search.fashion</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="fashion_season_id"/>
                <field name="fashion_family_id"/>
                <separator/>
                <filter string="Man" name="filter_man"
                        domain="[('fashion_gender', '=', 'man')]"/>
                <filter string="Woman" name="filter_woman"
                        domain="[('fashion_gender', '=', 'woman')]"/>
                <filter string="Boy" name="filter_boy"
                        domain="[('fashion_gender', '=', 'boy')]"/>
                <filter string="Girl" name="filter_girl"
                        domain="[('fashion_gender', '=', 'girl')]"/>
                <filter string="Baby" name="filter_baby"
                        domain="[('fashion_gender', '=', 'baby')]"/>
                <filter string="Unisex" name="filter_unisex"
                        domain="[('fashion_gender', '=', 'unisex')]"/>
                <separator/>
                <group>
                    <filter string="Season" name="group_season"
                            context="{'group_by': 'fashion_season_id'}"/>
                    <filter string="Family" name="group_family"
                            context="{'group_by': 'fashion_family_id'}"/>
                    <filter string="Gender" name="group_gender"
                            context="{'group_by': 'fashion_gender'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
