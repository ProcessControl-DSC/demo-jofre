<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_form_fashion" model="ir.ui.view">
        <field name="name">purchase.order.form.fashion</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Campos de moda después del partner -->
            <xpath expr="//field[@name='partner_id']/.." position="after">
                <group string="Información moda" name="fashion_info">
                    <group>
                        <field name="fashion_season_id"/>
                        <field name="fashion_gender"/>
                    </group>
                    <group>
                        <field name="fashion_family_id"/>
                        <field name="distribution_profile_id"/>
                    </group>
                </group>
            </xpath>

            <!-- Botón transferencias a tiendas en la sheet, después del grupo de moda -->
            <xpath expr="//group[@name='fashion_info']" position="after">
                <div class="oe_button_box" name="fashion_button_box">
                    <button name="action_create_store_transfers"
                            string="Distribuir a tiendas"
                            type="object"
                            class="oe_stat_button"
                            invisible="not distribution_data or state != 'purchase'"
                            icon="fa-truck"/>
                    <button name="action_view_store_pickings"
                            string="Transferencias"
                            type="object"
                            class="oe_stat_button"
                            invisible="store_picking_count == 0"
                            icon="fa-truck">
                        <field name="store_picking_count" widget="statinfo"/>
                    </button>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
