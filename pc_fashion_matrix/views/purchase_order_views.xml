<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Purchase Order: Extend Form View -->
    <record id="purchase_order_form_view_fashion" model="ir.ui.view">
        <field name="name">purchase.order.form.fashion</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Add Distribute to Stores button in header -->
            <xpath expr="//header" position="inside">
                <button name="action_distribute_to_stores"
                        string="Distribute to Stores"
                        type="object"
                        class="btn-primary"
                        invisible="state not in ('purchase', 'done') or not distribution_profile_id"
                        confirm="This will create internal transfers to distribute stock to stores based on the selected profile. Continue?"/>
            </xpath>

            <!-- Filter products by supplier on order lines -->
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes">
                <attribute name="domain">[('purchase_ok', '=', True), ('seller_ids.partner_id', '=', parent.partner_id)]</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_template_id']" position="attributes">
                <attribute name="domain">[('purchase_ok', '=', True), ('seller_ids.partner_id', '=', parent.partner_id)]</attribute>
            </xpath>

            <!-- Add fashion fields in a new tab before delivery/invoice -->
            <xpath expr="//page[@name='purchase_delivery_invoice']" position="before">
                <page string="Fashion" name="fashion_info">
                    <group>
                        <group string="Season &amp; Classification">
                            <field name="fashion_season_id"/>
                            <field name="fashion_gender"/>
                        </group>
                        <group string="Distribution">
                            <field name="distribution_profile_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
