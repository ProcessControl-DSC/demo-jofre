<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Fashion Product Family: Form View -->
    <record id="fashion_product_family_view_form" model="ir.ui.view">
        <field name="name">fashion.product.family.form</field>
        <field name="model">fashion.product.family</field>
        <field name="arch" type="xml">
            <form string="Product Family">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Pantalones"/>
                        </h1>
                    </div>
                    <group>
                        <field name="code" placeholder="e.g. PNT"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Fashion Product Family: List View -->
    <record id="fashion_product_family_view_list" model="ir.ui.view">
        <field name="name">fashion.product.family.list</field>
        <field name="model">fashion.product.family</field>
        <field name="arch" type="xml">
            <list string="Product Families" editable="bottom">
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Fashion Product Family: Action -->
    <record id="fashion_product_family_action" model="ir.actions.act_window">
        <field name="name">Product Families</field>
        <field name="res_model">fashion.product.family</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first product family
            </p>
            <p>
                Product families group your fashion items (e.g. Pantalones, Camisas, Chaquetas).
            </p>
        </field>
    </record>

</odoo>
