<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Store Distribution Profile: Form View -->
    <record id="store_distribution_profile_view_form" model="ir.ui.view">
        <field name="name">store.distribution.profile.form</field>
        <field name="model">store.distribution.profile</field>
        <field name="arch" type="xml">
            <form string="Distribution Profile">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Standard Distribution"/>
                        </h1>
                    </div>
                    <group>
                        <field name="total_percentage"
                               widget="progressbar"
                               options="{'max_value': 100}"/>
                        <field name="active" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Store Allocation" name="store_lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="warehouse_id"/>
                                    <field name="percentage"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Store Distribution Profile: List View -->
    <record id="store_distribution_profile_view_list" model="ir.ui.view">
        <field name="name">store.distribution.profile.list</field>
        <field name="model">store.distribution.profile</field>
        <field name="arch" type="xml">
            <list string="Distribution Profiles">
                <field name="name"/>
                <field name="total_percentage" widget="progressbar"
                       options="{'max_value': 100}"/>
            </list>
        </field>
    </record>

    <!-- Store Distribution Profile: Action -->
    <record id="store_distribution_profile_action" model="ir.actions.act_window">
        <field name="name">Distribution Profiles</field>
        <field name="res_model">store.distribution.profile</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first distribution profile
            </p>
            <p>
                Distribution profiles define how stock is allocated across your stores
                (warehouses) when distributing purchase orders.
            </p>
        </field>
    </record>

</odoo>
