<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pc_pos_transfers.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('navbar-menu')]" position="inside">
            <button class="btn btn-light btn-lg lh-lg"
                t-on-click="() => this.onClickTransfers()">
                <i class="fa fa-fw fa-exchange"/>
                <span t-if="!ui.isSmall"> Traslados</span>
            </button>
        </xpath>
    </t>

</templates>
