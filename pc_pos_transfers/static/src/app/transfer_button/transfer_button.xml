<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pc_pos_transfers.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('actionpad')]" position="inside">
            <button class="btn btn-lg btn-info d-flex align-items-center justify-content-center gap-2"
                    t-on-click="onClickTransferRequest">
                <i class="fa fa-exchange"/>
                <span>Traslado</span>
            </button>
        </xpath>
    </t>
</templates>
