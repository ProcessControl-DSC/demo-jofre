<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pc_pos_transfers.TransferRequestPopup">
        <Dialog title="'Solicitar traslado'" size="'md'">
            <div class="transfer-request-popup p-3">
                <!-- Product info -->
                <div class="mb-3 p-3 bg-light rounded">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="fa fa-cube fa-lg text-primary"/>
                        <h5 class="mb-0" t-esc="productName"/>
                    </div>
                    <div class="d-flex align-items-center gap-2 text-muted">
                        <i class="fa fa-warehouse"/>
                        <span>Desde: <strong t-esc="props.warehouseName"/></span>
                    </div>
                    <div class="d-flex align-items-center gap-2 text-muted mt-1">
                        <i class="fa fa-cubes"/>
                        <span>Disponible: <strong t-esc="props.availableQty"/> uds.</strong></span>
                    </div>
                </div>

                <!-- Quantity selector -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Cantidad a solicitar</label>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary btn-lg"
                                t-on-click="decrementQty"
                                t-att-disabled="state.qty &lt;= 1">
                            <i class="fa fa-minus"/>
                        </button>
                        <input type="number"
                               class="form-control form-control-lg text-center transfer-qty-input"
                               t-att-value="state.qty"
                               t-att-min="1"
                               t-att-max="maxQty"
                               t-on-change="onQtyChange"
                               style="max-width: 120px;"/>
                        <button class="btn btn-outline-secondary btn-lg"
                                t-on-click="incrementQty"
                                t-att-disabled="state.qty >= maxQty">
                            <i class="fa fa-plus"/>
                        </button>
                    </div>
                </div>

                <!-- Info message -->
                <div class="alert alert-info small mb-0">
                    <i class="fa fa-info-circle me-1"/>
                    Se creará un traslado interno desde
                    <strong t-esc="props.warehouseName"/>
                    hacia tu tienda.
                    El almacén de origen deberá preparar y enviar el pedido.
                </div>
            </div>

            <t t-set-slot="footer">
                <div class="d-flex gap-2 w-100">
                    <button class="btn btn-secondary btn-lg flex-grow-1"
                            t-on-click="onCancel"
                            t-att-disabled="state.isProcessing">
                        Cancelar
                    </button>
                    <button class="btn btn-primary btn-lg flex-grow-1"
                            t-on-click="onConfirm"
                            t-att-disabled="state.isProcessing">
                        <t t-if="state.isProcessing">
                            <i class="fa fa-spinner fa-spin me-1"/>Creando...
                        </t>
                        <t t-else="">
                            <i class="fa fa-check me-1"/>Solicitar traslado
                        </t>
                    </button>
                </div>
            </t>
        </Dialog>
    </t>

</templates>
