<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- Import Log — List View -->
    <!-- ================================================================== -->
    <record id="view_b2b_import_log_list" model="ir.ui.view">
        <field name="name">b2b.import.log.list</field>
        <field name="model">b2b.import.log</field>
        <field name="arch" type="xml">
            <list string="Historial de importaciones B2B"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'error'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="date_import"/>
                <field name="platform"/>
                <field name="file_name"/>
                <field name="supplier_name"/>
                <field name="po_number_external"/>
                <field name="purchase_order_id"/>
                <field name="products_created"/>
                <field name="products_matched"/>
                <field name="lines_imported"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'error'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Import Log — Form View -->
    <!-- ================================================================== -->
    <record id="view_b2b_import_log_form" model="ir.ui.view">
        <field name="name">b2b.import.log.form</field>
        <field name="model">b2b.import.log</field>
        <field name="arch" type="xml">
            <form string="Registro de importación B2B">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_order"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible="not purchase_order_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Pedido de compra</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información general">
                            <field name="platform" readonly="1"/>
                            <field name="file_name" readonly="1"/>
                            <field name="date_import" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="supplier_name" readonly="1"/>
                            <field name="po_number_external" readonly="1"/>
                        </group>
                        <group string="Estadísticas">
                            <field name="products_created" readonly="1"/>
                            <field name="products_matched" readonly="1"/>
                            <field name="lines_imported" readonly="1"/>
                        </group>
                    </group>

                    <group string="Error" invisible="state != 'error'">
                        <field name="error_message" readonly="1" nolabel="1"
                               colspan="2"/>
                    </group>

                    <notebook>
                        <page string="Líneas de detalle" name="log_lines">
                            <field name="log_line_ids" nolabel="1" readonly="1">
                                <list decoration-success="state == 'ok'"
                                      decoration-info="state == 'created'"
                                      decoration-danger="state == 'error'">
                                    <field name="line_number" string="Nº"/>
                                    <field name="style_number"/>
                                    <field name="color"/>
                                    <field name="size"/>
                                    <field name="quantity" sum="Total uds."/>
                                    <field name="price"/>
                                    <field name="retail_price"/>
                                    <field name="product_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'ok'"
                                           decoration-info="state == 'created'"
                                           decoration-danger="state == 'error'"/>
                                    <field name="message"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Import Log — Search View -->
    <!-- ================================================================== -->
    <record id="view_b2b_import_log_search" model="ir.ui.view">
        <field name="name">b2b.import.log.search</field>
        <field name="model">b2b.import.log</field>
        <field name="arch" type="xml">
            <search string="Buscar importaciones">
                <field name="name"/>
                <field name="file_name"/>
                <field name="supplier_name"/>
                <field name="po_number_external"/>
                <filter string="Completadas" name="filter_done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Con errores" name="filter_error"
                        domain="[('state', '=', 'error')]"/>
                <separator/>
                <filter string="JOOR" name="filter_joor"
                        domain="[('platform', '=', 'joor')]"/>
                <filter string="NuORDER" name="filter_nuorder"
                        domain="[('platform', '=', 'nuorder')]"/>
                <filter string="MIRRI" name="filter_mirri"
                        domain="[('platform', '=', 'mirri')]"/>
                <filter string="The New Black" name="filter_thenewblack"
                        domain="[('platform', '=', 'thenewblack')]"/>
                <separator/>
                <group>
                    <filter string="Plataforma" name="group_platform"
                            context="{'group_by': 'platform'}"/>
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Fecha" name="group_date"
                            context="{'group_by': 'date_import:month'}"/>
                    <filter string="Usuario" name="group_user"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Import Log — Action -->
    <!-- ================================================================== -->
    <record id="action_b2b_import_log" model="ir.actions.act_window">
        <field name="name">Historial de importaciones</field>
        <field name="res_model">b2b.import.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_b2b_import_log_search"/>
        <field name="context">{'search_default_filter_done': 1}</field>
    </record>

</odoo>
