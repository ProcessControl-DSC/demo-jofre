<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Add "Reservar" button in the ActionpadWidget, alongside Customer/Note/Alteration -->
    <t t-name="pc_product_reservation.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('actionpad')]" position="inside">
            <button class="btn btn-lg d-flex align-items-center justify-content-center gap-2"
                style="background-color: #e67e22; color: white; font-weight: 700;"
                t-on-click="onClickReserve">
                <i class="fa fa-bookmark"/>
                <span>Reservar</span>
            </button>
        </xpath>
    </t>

</templates>
