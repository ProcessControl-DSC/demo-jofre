<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_cron_expire_reservations" model="ir.cron">
        <field name="name">Reservas de producto: expirar automáticamente</field>
        <field name="model_id" ref="model_product_reservation"/>
        <field name="state">code</field>
        <field name="code">model._cron_expire_reservations()</field>
        <field name="interval_number">4</field>
        <field name="interval_type">hours</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=6, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active" eval="True"/>
    </record>

</odoo>
