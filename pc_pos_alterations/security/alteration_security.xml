<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="privilege_pos_alterations" model="res.groups.privilege">
        <field name="name">Arreglos TPV</field>
        <field name="category_id" ref="base.module_category_point_of_sale"/>
    </record>

    <record id="group_alteration_user" model="res.groups">
        <field name="name">Usuario de arreglos</field>
        <field name="privilege_id" ref="privilege_pos_alterations"/>
        <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
    </record>

    <record id="group_alteration_manager" model="res.groups">
        <field name="name">Administrador de arreglos</field>
        <field name="privilege_id" ref="privilege_pos_alterations"/>
        <field name="implied_ids" eval="[(4, ref('group_alteration_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
