<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_pos_alterations" model="ir.module.category">
        <field name="name">Arreglos TPV</field>
        <field name="description">Gestión de arreglos de ropa desde el TPV</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_alteration_user" model="res.groups">
        <field name="name">Usuario de arreglos</field>
        <field name="category_id" ref="point_of_sale.module_category_point_of_sale"/>
        <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
    </record>

    <record id="group_alteration_manager" model="res.groups">
        <field name="name">Administrador de arreglos</field>
        <field name="category_id" ref="point_of_sale.module_category_point_of_sale"/>
        <field name="implied_ids" eval="[(4, ref('group_alteration_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Regla: los usuarios de arreglos solo ven los de su compañía -->
    <record id="alteration_comp_rule" model="ir.rule">
        <field name="name">Arreglos: regla multi-compañía</field>
        <field name="model_id" ref="model_pos_alteration"/>
        <field name="domain_force">[('warehouse_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_alteration_user'))]"/>
    </record>

</odoo>
