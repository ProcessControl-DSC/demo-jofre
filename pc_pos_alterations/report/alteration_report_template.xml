<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="alteration_ticket">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="alt">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: monospace; font-size: 12px;">

                        <!-- Cabecera tienda -->
                        <div class="text-center mb-3">
                            <h3 t-if="alt.warehouse_id">
                                <t t-out="alt.warehouse_id.name"/>
                            </h3>
                            <div t-if="alt.warehouse_id and alt.warehouse_id.partner_id">
                                <span t-if="alt.warehouse_id.partner_id.street"
                                      t-out="alt.warehouse_id.partner_id.street"/>
                                <br/>
                                <span t-if="alt.warehouse_id.partner_id.city">
                                    <t t-out="alt.warehouse_id.partner_id.zip"/>
                                    <t t-out="alt.warehouse_id.partner_id.city"/>
                                </span>
                                <br/>
                                <span t-if="alt.warehouse_id.partner_id.phone">
                                    Tel: <t t-out="alt.warehouse_id.partner_id.phone"/>
                                </span>
                            </div>
                        </div>

                        <hr style="border-top: 2px dashed #000;"/>

                        <!-- Titulo -->
                        <div class="text-center mb-3">
                            <h2>TICKET DE ARREGLO</h2>
                        </div>

                        <!-- Referencia y código de barras -->
                        <div class="text-center mb-3">
                            <h4><t t-out="alt.name"/></h4>
                            <div t-if="alt.name">
                                <img t-att-src="'/report/barcode/?barcode_type=Code128&amp;value=%s&amp;width=300&amp;height=50&amp;humanreadable=1' % alt.name"
                                     style="max-width: 80%;"/>
                            </div>
                        </div>

                        <hr style="border-top: 1px solid #000;"/>

                        <!-- Cliente -->
                        <div class="mb-2">
                            <strong>Cliente:</strong>
                            <span t-out="alt.partner_id.name or 'Sin identificar'"/>
                            <br t-if="alt.partner_id.phone or alt.partner_id.mobile"/>
                            <span t-if="alt.partner_id.phone or alt.partner_id.mobile">
                                <strong>Teléfono:</strong>
                                <t t-out="alt.partner_id.phone or alt.partner_id.mobile"/>
                            </span>
                        </div>

                        <hr style="border-top: 1px solid #000;"/>

                        <!-- Producto -->
                        <div class="mb-2">
                            <strong>Producto:</strong>
                            <span t-out="alt.product_id.display_name if alt.product_id else 'N/A'"/>
                        </div>

                        <!-- Tipo de arreglo -->
                        <div class="mb-2">
                            <strong>Tipo de arreglo:</strong>
                            <span t-out="alt.alteration_type_id.name"/>
                        </div>

                        <!-- Descripción -->
                        <div class="mb-2" t-if="alt.description">
                            <strong>Descripción:</strong>
                            <span t-out="alt.description"/>
                        </div>

                        <!-- Coste -->
                        <div class="mb-2">
                            <strong>Valor del arreglo:</strong>
                            <span t-out="'%.2f' % alt.cost"/> EUR
                            <span t-if="not alt.charged_to_customer" class="ms-1">(Cortesía)</span>
                        </div>

                        <hr style="border-top: 1px solid #000;"/>

                        <!-- Fecha entrega -->
                        <div class="mb-2">
                            <strong>Fecha de entrega prevista:</strong>
                            <span t-out="alt.date_promised" t-options="{'widget': 'date'}"/>
                        </div>

                        <!-- Método de entrega -->
                        <div class="mb-2">
                            <strong>Método de entrega:</strong>
                            <span t-if="alt.delivery_method == 'pickup_store'">Recogida en tienda</span>
                            <span t-if="alt.delivery_method == 'ship_customer'">Envío a domicilio</span>
                        </div>

                        <hr style="border-top: 2px dashed #000;"/>

                        <!-- Pie -->
                        <div class="text-center mt-3" style="font-size: 11px;">
                            <p><strong>Conserve este ticket.</strong></p>
                            <p>Necesario para recoger su prenda.</p>
                        </div>

                        <!-- Fecha impresión -->
                        <div class="text-center mt-2" style="font-size: 10px; color: #666;">
                            <span>Impreso: <t t-out="context_timestamp(alt.date_created)" t-options="{'widget': 'datetime'}"/></span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
