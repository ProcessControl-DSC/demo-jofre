<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====== FORM VIEW ====== -->
    <record id="alteration_type_view_form" model="ir.ui.view">
        <field name="name">alteration.type.form</field>
        <field name="model">alteration.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Arreglo">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Ej: Dobladillo"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="product_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="default_duration_days"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ====== LIST VIEW ====== -->
    <record id="alteration_type_view_list" model="ir.ui.view">
        <field name="name">alteration.type.list</field>
        <field name="model">alteration.type</field>
        <field name="arch" type="xml">
            <list string="Tipos de Arreglo" editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="product_id"/>
                <field name="default_duration_days"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ====== ACTION ====== -->
    <record id="action_alteration_type" model="ir.actions.act_window">
        <field name="name">Tipos de Arreglo</field>
        <field name="res_model">alteration.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Defina los tipos de arreglo disponibles
            </p>
            <p>
                Cada tipo de arreglo tiene un coste y una duración estimada por defecto.
            </p>
        </field>
    </record>

</odoo>
