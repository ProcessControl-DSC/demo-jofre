<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====== FORM VIEW ====== -->
    <record id="pos_alteration_view_form" model="ir.ui.view">
        <field name="name">pos.alteration.form</field>
        <field name="model">pos.alteration</field>
        <field name="arch" type="xml">
            <form string="Arreglo de Prenda">
                <header>
                    <button name="action_start" string="Iniciar Trabajo"
                            type="object" class="oe_highlight"
                            invisible="state != 'pending'"/>
                    <button name="action_ready" string="Marcar Listo"
                            type="object" class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_deliver" string="Marcar Entregado"
                            type="object" class="oe_highlight"
                            invisible="state != 'ready'"/>
                    <button name="action_cancel" string="Cancelar"
                            type="object"
                            invisible="state in ('delivered', 'cancelled')"
                            confirm="¿Está seguro de que desea cancelar este arreglo?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,in_progress,ready,delivered"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(pc_pos_alterations.action_pos_alteration_report)d"
                                type="action" class="oe_stat_button" icon="fa-print"
                                string="Imprimir Ticket"/>
                        <button type="object" name="action_view_pos_order"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="not pos_order_id">
                            <span>Pedido TPV</span>
                        </button>
                        <button type="object" name="action_view_stock_moves"
                                class="oe_stat_button" icon="fa-truck">
                            <span>Movimientos</span>
                        </button>
                        <button type="object" name="action_view_calendar_event"
                                class="oe_stat_button" icon="fa-calendar"
                                invisible="not calendar_event_id">
                            <span>Evento</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información del arreglo">
                            <field name="alteration_type_id"/>
                            <field name="description" placeholder="Ej: Acortar 3cm pierna derecha"/>
                            <field name="cost"/>
                            <field name="charged_to_customer"/>
                            <field name="delivery_method"/>
                        </group>
                        <group string="Cliente y producto">
                            <field name="partner_id"/>
                            <field name="product_id"/>
                            <field name="pos_order_id" readonly="1"/>
                            <field name="pos_order_line_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Asignación">
                            <field name="user_id" readonly="1"/>
                            <field name="tailor_id"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group string="Fechas">
                            <field name="date_created"/>
                            <field name="date_promised"/>
                            <field name="date_done"/>
                            <field name="date_delivered"/>
                            <field name="is_overdue" invisible="1"/>
                        </group>
                    </group>
                    <group string="Stock" invisible="not move_to_workshop_id and not move_to_store_id">
                        <field name="move_to_workshop_id" readonly="1"/>
                        <field name="move_to_store_id" readonly="1"/>
                    </group>
                    <field name="calendar_event_id" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ====== LIST VIEW ====== -->
    <record id="pos_alteration_view_list" model="ir.ui.view">
        <field name="name">pos.alteration.list</field>
        <field name="model">pos.alteration</field>
        <field name="arch" type="xml">
            <list string="Arreglos" decoration-danger="is_overdue"
                  decoration-success="state == 'ready'"
                  decoration-warning="state == 'in_progress'"
                  decoration-muted="state in ('cancelled', 'delivered')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="alteration_type_id"/>
                <field name="warehouse_id"/>
                <field name="date_promised"/>
                <field name="tailor_id"/>
                <field name="cost" sum="Coste total"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'ready'"
                       decoration-muted="state in ('cancelled', 'delivered')"/>
                <field name="is_overdue" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ====== KANBAN VIEW ====== -->
    <record id="pos_alteration_view_kanban" model="ir.ui.view">
        <field name="name">pos.alteration.kanban</field>
        <field name="model">pos.alteration</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column"
                    records_draggable="0">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="alteration_type_id"/>
                <field name="date_promised"/>
                <field name="state"/>
                <field name="is_overdue"/>
                <field name="cost"/>
                <field name="delivery_method"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top mb-0">
                            <div class="o_kanban_record_headings">
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </div>
                            <field name="state" widget="label_selection"
                                   options="{'classes': {
                                       'pending': 'info',
                                       'in_progress': 'warning',
                                       'ready': 'success',
                                       'delivered': 'secondary',
                                       'cancelled': 'danger'
                                   }}"/>
                        </div>
                        <div class="o_kanban_record_body">
                            <div><strong><field name="partner_id"/></strong></div>
                            <div><field name="product_id"/></div>
                            <div class="text-muted">
                                <field name="alteration_type_id"/>
                            </div>
                            <div t-attf-class="#{record.is_overdue.raw_value ? 'text-danger fw-bold' : ''}">
                                <i class="fa fa-calendar"/> <field name="date_promised"/>
                            </div>
                            <div class="text-muted">
                                <field name="cost" widget="monetary"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ====== CALENDAR VIEW ====== -->
    <record id="pos_alteration_view_calendar" model="ir.ui.view">
        <field name="name">pos.alteration.calendar</field>
        <field name="model">pos.alteration</field>
        <field name="arch" type="xml">
            <calendar string="Arreglos" date_start="date_created" date_stop="date_promised"
                      color="state" mode="month" quick_create="0"
                      event_open_popup="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="alteration_type_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- ====== SEARCH VIEW ====== -->
    <record id="pos_alteration_view_search" model="ir.ui.view">
        <field name="name">pos.alteration.search</field>
        <field name="model">pos.alteration</field>
        <field name="arch" type="xml">
            <search string="Buscar arreglos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="alteration_type_id"/>
                <field name="tailor_id"/>
                <separator/>
                <filter string="Pendientes" name="filter_pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter string="En Curso" name="filter_in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Listos para recoger" name="filter_ready"
                        domain="[('state', '=', 'ready')]"/>
                <filter string="Entregados" name="filter_delivered"
                        domain="[('state', '=', 'delivered')]"/>
                <separator/>
                <filter string="Vencidos" name="filter_overdue"
                        domain="[('is_overdue', '=', True)]"/>
                <filter string="Próximos 7 días" name="filter_this_week"
                        domain="[('date_promised', '&gt;=', 'today'),
                                 ('date_promised', '&lt;', 'today +8d')]"/>
                <separator/>
                <filter string="Mi tienda" name="filter_my_store"
                        domain="[('warehouse_id.company_id', 'in', allowed_company_ids)]"/>
                <group>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Tienda" name="group_warehouse" context="{'group_by': 'warehouse_id'}"/>
                    <filter string="Tipo de arreglo" name="group_type" context="{'group_by': 'alteration_type_id'}"/>
                    <filter string="Costurera" name="group_tailor" context="{'group_by': 'tailor_id'}"/>
                    <filter string="Fecha prometida" name="group_date" context="{'group_by': 'date_promised:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ====== ACTIONS ====== -->
    <record id="action_pos_alteration" model="ir.actions.act_window">
        <field name="name">Arreglos</field>
        <field name="res_model">pos.alteration</field>
        <field name="view_mode">list,kanban,form,calendar</field>
        <field name="search_view_id" ref="pos_alteration_view_search"/>
        <field name="context">{'search_default_filter_pending': 1, 'search_default_filter_in_progress': 1, 'search_default_filter_ready': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay arreglos registrados
            </p>
            <p>
                Los arreglos se crean desde el Punto de Venta al marcar prendas para arreglo.
            </p>
        </field>
    </record>

    <!-- Smart button actions -->
    <record id="action_pos_alteration_stock_moves" model="ir.actions.act_window">
        <field name="name">Movimientos de stock</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
