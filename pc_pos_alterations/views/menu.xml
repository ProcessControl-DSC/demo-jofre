<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción para ver arreglos TPV (repair.order con pos_order_id) -->
    <record id="action_pos_repair_alterations" model="ir.actions.act_window">
        <field name="name">Arreglos TPV</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_pos_alterations': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay arreglos registrados
            </p>
            <p>
                Los arreglos se crean desde el Punto de Venta al marcar prendas para arreglo.
            </p>
        </field>
    </record>

    <!-- Menú principal bajo Punto de Venta -->
    <menuitem id="menu_pos_alterations_root"
              name="Arreglos"
              parent="point_of_sale.menu_point_root"
              sequence="30"/>

    <menuitem id="menu_pos_alterations"
              name="Arreglos TPV"
              parent="menu_pos_alterations_root"
              action="action_pos_repair_alterations"
              sequence="10"/>

    <menuitem id="menu_alteration_types"
              name="Tipos de Arreglo"
              parent="menu_pos_alterations_root"
              action="action_alteration_type"
              sequence="20"
              groups="group_alteration_manager"/>

</odoo>
