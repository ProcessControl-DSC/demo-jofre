<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pc_pos_alterations.AlterationScreen">
        <div class="alteration-screen d-flex flex-column h-100">
            <!-- Header -->
            <div class="alteration-screen-header d-flex align-items-center p-3 bg-dark text-white">
                <button class="btn btn-outline-light me-3" t-on-click="onClickBack">
                    <i class="fa fa-arrow-left me-1"/>Volver
                </button>
                <h3 class="mb-0 flex-grow-1">
                    <i class="fa fa-scissors me-2"/>Arreglos
                </h3>
                <div class="d-flex align-items-center gap-2">
                    <div class="input-group" style="width: 280px;">
                        <span class="input-group-text"><i class="fa fa-search"/></span>
                        <input type="text" class="form-control"
                               placeholder="Buscar cliente o referencia..."
                               t-att-value="state.searchTerm"
                               t-on-input="onSearchInput"
                               t-on-keydown="onSearchKeydown"/>
                    </div>
                </div>
            </div>

            <!-- Filter tabs -->
            <div class="alteration-filters d-flex gap-2 p-2 bg-light border-bottom">
                <button t-attf-class="btn btn-sm {{ state.activeFilter === 'all' ? 'btn-primary' : 'btn-outline-secondary' }}"
                        t-on-click="() => this.onFilterChange('all')">
                    Todos
                </button>
                <button t-attf-class="btn btn-sm {{ state.activeFilter === 'draft' ? 'btn-info' : 'btn-outline-secondary' }}"
                        t-on-click="() => this.onFilterChange('draft')">
                    <i class="fa fa-file-o me-1"/>Borrador
                </button>
                <button t-attf-class="btn btn-sm {{ state.activeFilter === 'confirmed' ? 'btn-primary' : 'btn-outline-secondary' }}"
                        t-on-click="() => this.onFilterChange('confirmed')">
                    <i class="fa fa-check-circle me-1"/>Confirmadas
                </button>
                <button t-attf-class="btn btn-sm {{ state.activeFilter === 'under_repair' ? 'btn-warning' : 'btn-outline-secondary' }}"
                        t-on-click="() => this.onFilterChange('under_repair')">
                    <i class="fa fa-cog fa-spin me-1"/>En Curso
                </button>
                <button t-attf-class="btn btn-sm {{ state.activeFilter === 'done' ? 'btn-success' : 'btn-outline-secondary' }}"
                        t-on-click="() => this.onFilterChange('done')">
                    <i class="fa fa-check me-1"/>Finalizadas
                </button>
            </div>

            <!-- Content -->
            <div class="alteration-content flex-grow-1 overflow-auto p-3">
                <!-- Loading -->
                <t t-if="state.loading">
                    <div class="text-center py-5">
                        <i class="fa fa-spinner fa-spin fa-3x text-muted"/>
                        <p class="mt-2 text-muted">Cargando arreglos...</p>
                    </div>
                </t>

                <!-- Empty state -->
                <t t-elif="!state.alterations.length">
                    <div class="text-center py-5">
                        <i class="fa fa-scissors fa-3x text-muted mb-3"/>
                        <p class="text-muted fs-5">No hay arreglos para mostrar</p>
                    </div>
                </t>

                <!-- Alteration cards -->
                <t t-else="">
                    <div class="row g-3">
                        <t t-foreach="state.alterations" t-as="alt" t-key="alt.id">
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="card alteration-card h-100 shadow-sm">
                                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                                        <span class="fw-bold" t-esc="alt.name"/>
                                        <span t-attf-class="badge {{ getStateBadgeClass(alt.state) }}">
                                            <t t-esc="getStateLabel(alt.state)"/>
                                        </span>
                                    </div>
                                    <div class="card-body py-2">
                                        <!-- Customer -->
                                        <div class="mb-1">
                                            <i class="fa fa-user text-muted me-1"/>
                                            <strong t-esc="alt.partner_name"/>
                                        </div>
                                        <!-- Product -->
                                        <div class="mb-1 text-muted small">
                                            <i class="fa fa-tag me-1"/>
                                            <t t-esc="alt.product_name"/>
                                        </div>
                                        <!-- Alteration type -->
                                        <t t-if="alt.alteration_type">
                                            <div class="mb-1">
                                                <i class="fa fa-scissors me-1"/>
                                                <t t-esc="alt.alteration_type"/>
                                            </div>
                                        </t>
                                        <!-- Description (HTML stripped for display) -->
                                        <t t-if="alt.description">
                                            <div class="mb-1 small fst-italic text-muted">
                                                "<t t-esc="alt.description"/>"
                                            </div>
                                        </t>
                                        <!-- Dates -->
                                        <div class="d-flex justify-content-between small mt-2">
                                            <span t-attf-class="{{ alt.is_overdue ? 'text-danger fw-bold' : 'text-muted' }}">
                                                <i class="fa fa-calendar me-1"/>
                                                <t t-esc="alt.date_promised"/>
                                            </span>
                                            <span>
                                                <t t-if="alt.delivery_method">
                                                    <i t-attf-class="fa {{ alt.delivery_method === 'pickup_store' ? 'fa-home' : 'fa-truck' }} me-1"/>
                                                    <t t-esc="getDeliveryMethodLabel(alt.delivery_method)"/>
                                                </t>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="card-footer d-flex gap-1 py-2">
                                        <t t-if="canConfirm(alt)">
                                            <button class="btn btn-sm btn-info flex-fill"
                                                    t-on-click="() => this.onActionConfirm(alt)">
                                                <i class="fa fa-check-circle me-1"/>Confirmar
                                            </button>
                                        </t>
                                        <t t-if="canStart(alt)">
                                            <button class="btn btn-sm btn-warning flex-fill"
                                                    t-on-click="() => this.onActionStart(alt)">
                                                <i class="fa fa-play me-1"/>Iniciar
                                            </button>
                                        </t>
                                        <t t-if="canEnd(alt)">
                                            <button class="btn btn-sm btn-success flex-fill"
                                                    t-on-click="() => this.onActionEnd(alt)">
                                                <i class="fa fa-check me-1"/>Finalizar
                                            </button>
                                        </t>
                                        <t t-if="canCancel(alt)">
                                            <button class="btn btn-sm btn-outline-danger"
                                                    t-on-click="() => this.onActionCancel(alt)">
                                                <i class="fa fa-times"/>
                                            </button>
                                        </t>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                t-on-click="() => this.onPrintReceipt(alt)">
                                            <i class="fa fa-print"/>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
