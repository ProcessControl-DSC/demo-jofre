<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Añadir botón "Arreglo" al ActionpadWidget, junto a Payment -->
    <t t-name="pc_pos_alterations.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('actionpad')]" position="inside">
            <button class="btn btn-secondary btn-lg d-flex align-items-center justify-content-center gap-2"
                    t-on-click="onClickAlteration">
                <i class="fa fa-scissors"/>
                <span>Arreglo</span>
            </button>
        </xpath>
    </t>

</templates>
