<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pc_pos_alterations.AlterationReceipt">
        <div class="pos-receipt alteration-receipt">

            <!-- ============ LOGO EMPRESA ============ -->
            <t t-if="props.alteration.company_logo">
                <div class="receipt-logo">
                    <img t-att-src="'data:image/png;base64,' + props.alteration.company_logo"
                         alt="Logo"/>
                </div>
            </t>

            <!-- ============ HEADER: Tienda ============ -->
            <div class="receipt-header">
                <t t-if="storeName">
                    <div class="receipt-store-name">
                        <t t-esc="storeName"/>
                    </div>
                </t>
                <t t-if="storeAddress">
                    <div class="receipt-store-address">
                        <t t-esc="storeAddress"/>
                    </div>
                </t>
            </div>

            <!-- ============ TITULO ============ -->
            <div class="receipt-title-bar">
                <div class="receipt-title">ARREGLO DE PRENDA</div>
            </div>

            <!-- ============ FECHA/HORA ============ -->
            <div class="receipt-datetime">
                <t t-esc="currentDateTime"/>
            </div>

            <!-- ============ REFERENCIA ============ -->
            <t t-if="orderReference">
                <div class="receipt-reference">
                    <t t-esc="orderReference"/>
                </div>
            </t>

            <div class="receipt-separator"/>

            <!-- ============ CLIENTE ============ -->
            <div class="receipt-section">
                <div class="receipt-section-title">CLIENTE</div>
                <div class="receipt-row">
                    <span class="receipt-label">Nombre:</span>
                    <span class="receipt-value" t-esc="customerName"/>
                </div>
                <t t-if="customerPhone">
                    <div class="receipt-row">
                        <span class="receipt-label">Tel:</span>
                        <span class="receipt-value" t-esc="customerPhone"/>
                    </div>
                </t>
            </div>

            <div class="receipt-separator"/>

            <!-- ============ PRENDA ============ -->
            <div class="receipt-section">
                <div class="receipt-section-title">PRENDA</div>
                <div class="receipt-row">
                    <span class="receipt-label">Producto:</span>
                    <span class="receipt-value" t-esc="productName"/>
                </div>
                <t t-if="productRef">
                    <div class="receipt-row">
                        <span class="receipt-label">Ref:</span>
                        <span class="receipt-value" t-esc="productRef"/>
                    </div>
                </t>
            </div>

            <div class="receipt-separator"/>

            <!-- ============ DETALLES DEL ARREGLO ============ -->
            <div class="receipt-section">
                <div class="receipt-section-title">DETALLES DEL ARREGLO</div>
                <t t-if="alterationType">
                    <div class="receipt-row">
                        <span class="receipt-label">Tipo:</span>
                        <span class="receipt-value" t-esc="alterationType"/>
                    </div>
                </t>
                <t t-if="description">
                    <div class="receipt-row receipt-notes">
                        <span class="receipt-label">Notas:</span>
                        <span class="receipt-value" t-esc="description"/>
                    </div>
                </t>
                <t t-if="formattedDatePromised">
                    <div class="receipt-row">
                        <span class="receipt-label">Fecha:</span>
                        <span class="receipt-value" t-esc="formattedDatePromised"/>
                    </div>
                </t>
                <t t-if="deliveryMethodText">
                    <div class="receipt-row">
                        <span class="receipt-label">Entrega:</span>
                        <span class="receipt-value" t-esc="deliveryMethodText"/>
                    </div>
                </t>
            </div>

            <!-- ============ ESTADO ============ -->
            <t t-if="stateLabel">
                <div class="receipt-row">
                    <span class="receipt-label">Estado:</span>
                    <span class="receipt-value" t-esc="stateLabel"/>
                </div>
            </t>

            <!-- ============ FOOTER ============ -->
            <div class="receipt-footer-bar"/>

            <div class="receipt-footer">
                <div class="receipt-footer-main">Conserve este ticket</div>
                <div class="receipt-footer-sub">para recoger su prenda.</div>
            </div>

            <t t-if="orderReference">
                <div class="receipt-footer-ref">
                    Ref. pedido: <t t-esc="orderReference"/>
                </div>
            </t>

        </div>
    </t>

</templates>
